<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/reminderMainContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/reminderLeadingIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_bell"
            app:tint="@color/text_muted" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reminderAmountButton"
            android:layout_width="64dp"
            android:layout_height="30dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_reminder_pill"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="6dp"
            android:text="10"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:backgroundTint="#050505"
            app:cornerRadius="15dp"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reminderDurationButton"
            android:layout_width="94dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_reminder_pill"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="6dp"
            android:text="Minutes"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:backgroundTint="#050505"
            app:cornerRadius="15dp"
            app:strokeWidth="0dp" />

        <TextView
            android:id="@+id/reminderBeforeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Before"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />


    </LinearLayout>

    <ImageButton
        android:id="@+id/reminderRemoveButton"
        android:layout_width="48dp"
        android:layout_height="28dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_reminder_pill"
        android:contentDescription="Delete alarm"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_delete"
        app:backgroundTint="@color/delete"
        app:tint="@color/text_muted" />

</LinearLayout>