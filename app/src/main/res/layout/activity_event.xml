<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/eventHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/event_blue"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="60dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Back"
                android:src="@drawable/ic_arrow_left"
                android:tint="@color/white" />

            <TextView
                android:id="@+id/eventTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Saturday Event of Fun"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/editButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Edit"
                android:src="@drawable/ic_edit"
                android:tint="@color/white" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <com.example.rememberme.IconTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:rowIcon="@drawable/ic_arrow_left"
                app:rowIconTint="@color/text_muted"
                app:rowText="Tuesday, Mar 10 • 12:30 PM"
                app:rowTextColor="@color/text_primary" />

            <com.example.rememberme.IconTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:rowIcon="@drawable/ic_repeat"
                app:rowIconTint="@color/text_muted"
                app:rowText="Repeats weekly on Sat"
                app:rowTextColor="@color/text_primary" />

        </LinearLayout>

        <include layout="@layout/view_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <com.example.rememberme.IconTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:rowIcon="@drawable/ic_location"
                app:rowIconTint="@color/text_muted"
                app:rowText="Bell Labs"
                app:rowTextColor="@color/text_primary" />

            <com.example.rememberme.IconTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:rowIcon="@drawable/ic_paint"
                app:rowIconTint="@color/text_muted"
                app:rowText="🔵 Cyan"
                app:rowTextColor="@color/text_primary" />

        </LinearLayout>

        <include layout="@layout/view_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp">

            <com.example.rememberme.IconTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:rowIcon="@drawable/ic_bell"
                app:rowIconTint="@color/text_muted"
                app:rowText="Notifications"
                app:rowTextColor="@color/text_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_section_box"
                android:orientation="vertical"
                android:padding="12dp">

                <com.example.rememberme.IconTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:rowIcon="@drawable/ic_bell"
                    app:rowIconTint="@color/text_muted"
                    app:rowText="10 Minutes Before • Mobile"
                    app:rowTextColor="@color/text_primary" />

                <com.example.rememberme.IconTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:rowIcon="@drawable/ic_bell"
                    app:rowIconTint="@color/text_muted"
                    app:rowText="1 Hour Before • Mobile"
                    app:rowTextColor="@color/text_primary" />

                <com.example.rememberme.IconTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:rowIcon="@drawable/ic_bell"
                    app:rowIconTint="@color/text_muted"
                    app:rowText="1 Day Before • Mobile"
                    app:rowTextColor="@color/text_primary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/deleteButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#D32F2F"
        android:text="Delete Event"
        android:textColor="@color/white"
        app:icon="@drawable/ic_delete"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/white" />

</LinearLayout>