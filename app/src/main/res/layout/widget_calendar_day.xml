<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp"
    android:layout_height="112dp"
    android:layout_weight="1"
    android:background="@drawable/bg_calendar_day"
    android:orientation="vertical">

    <TextView
        android:id="@+id/dayNumberText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:text="11"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <com.example.rememberme.EventChipView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        app:eventTextSize="8sp"
        app:eventPaddingHorizontal="3dp"
        app:eventPaddingVertical="0dp"
        app:eventText="Church"
        app:eventColor="@color/event_white"
        app:eventConfirmed="true"
        app:eventDarkText="true" />

    <com.example.rememberme.EventChipView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        app:eventTextSize="8sp"
        app:eventPaddingHorizontal="3dp"
        app:eventPaddingVertical="0dp"
        app:eventText="Movie Night"
        app:eventColor="@color/event_blue"
        app:eventConfirmed="false"
        app:eventDarkText="false" />

    <com.example.rememberme.EventChipView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        app:eventTextSize="8sp"
        app:eventPaddingHorizontal="3dp"
        app:eventPaddingVertical="0dp"
        app:eventText="Sleep"
        app:eventColor="@color/event_orange"
        app:eventConfirmed="true"
        app:eventDarkText="false" />

</LinearLayout>