<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="390dp"
    android:layout_height="wrap_content"
    xmlns:andriod="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_surface"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            app:srcCompat="@drawable/ic_bell_plus" />

        <TextView
            android:id="@+id/notifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Notification"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/repeatRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioDoesNotRepeat"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:includeFontPadding="false"
            android:minHeight="36dp"
            android:text="Does Not Repeat"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radioEveryYear"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minHeight="36dp"
            android:includeFontPadding="false"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:text="Every year"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radioEveryMonth"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minHeight="36dp"
            android:includeFontPadding="false"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:text="Every month"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radioEveryWeek"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minHeight="36dp"
            android:includeFontPadding="false"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:text="Every week"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

    </RadioGroup>

</LinearLayout>