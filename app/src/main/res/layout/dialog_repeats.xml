<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="390dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_surface"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            app:srcCompat="@drawable/ic_repeat" />

        <TextView
            android:id="@+id/notifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeats"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/repeatRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioDoesNotRepeat"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:includeFontPadding="false"
            android:minHeight="36dp"
            android:text="Does Not Repeat"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radioEveryYear"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minHeight="36dp"
            android:includeFontPadding="false"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:text="Every year"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radioEveryMonth"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minHeight="36dp"
            android:includeFontPadding="false"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:text="Every month"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radioEveryWeek"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minHeight="36dp"
            android:includeFontPadding="false"
            android:buttonTint="@color/text_muted"
            android:drawablePadding="8dp"
            android:text="Every week"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_section_box"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="0dp">

        <CheckBox
            android:id="@+id/checkSunday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:buttonTint="@color/text_muted"
            android:gravity="center"
            android:text="S"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkMonday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:buttonTint="@color/text_muted"
            android:gravity="center"
            android:text="M"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkTuesday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:buttonTint="@color/text_muted"
            android:gravity="center"
            android:text="T"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkWednesday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:buttonTint="@color/text_muted"
            android:gravity="center"
            android:text="W"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkThursday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:buttonTint="@color/text_muted"
            android:gravity="center"
            android:text="T"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkFriday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:buttonTint="@color/text_muted"
            android:gravity="center"
            android:text="F"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkSaturday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:buttonTint="@color/text_muted"
            android:gravity="center"
            android:text="S"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>